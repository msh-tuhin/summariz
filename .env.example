# API Keys for YouTube Content Summarizer

# Gladia API key for audio transcription
GLADIA_API_KEY=your_gladia_api_key_here

# OpenAI API key for GPT models
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key for Claude models
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama API key for cloud models (optional, falls back to local)
OLLAMA_API_KEY=your_ollama_api_key_here

# YouTube download options (optional)
# Path to cookies.txt file exported from browser
YT_COOKIES_FILE=/path/to/www.youtube.com_cookies.txt
# Path to Node.js executable (for JS extraction)
YT_JS_RUNTIME=/usr/bin/node
# Set to "1" to skip SSL certificate verification
YT_NO_CHECK_CERTS=0
